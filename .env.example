# Backend
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_ORGANIZATION=
VOICE_MODULE_PROVIDER_MODE=mock
VOICE_MODULE_REALTIME_MODEL=gpt-realtime-2
VOICE_MODULE_REALTIME_VOICE=marin
VOICE_MODULE_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
VOICE_MODULE_TEXT_MODEL=gpt-5.5
VOICE_MODULE_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Browser WebRTC ICE configuration.
# STUN is included by default. Use TURN for restrictive networks, mobile carriers, VPNs, and enterprise firewalls.
VOICE_MODULE_ICE_SERVERS_JSON=[{"urls":["stun:stun.l.google.com:19302"]}]

# Frontend
VITE_VOICE_MODULE_API_BASE=http://127.0.0.1:8787
